---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const allTils = await getCollection('til')
const tilsData = allTils
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((til) => ({
    title: til.data.title,
    date: til.data.date,
    tag: til.data.tag,
    summary: til.data.summary,
  }))
---
<BaseLayout title="TIL | Iliass Tahiri" description="Short, frequent notes and lessons learned">
  <div class="container" style="padding-bottom: 80px;">
    <section class="page-hero">
      <span class="kicker">TIL</span>
      <h1 class="section-title">Today I Learned</h1>
      <p class="lead">Short, frequent notes from the workbench.</p>
    </section>

    <div class="post-grid">
      {tilsData.map((til) => (
        <article class="til-card">
          <div class="post-meta">
            <span>{til.date}</span>
            <span class="tag">{til.tag}</span>
          </div>
          <h3 style="margin-bottom: 0;">{til.title}</h3>
          <p>{til.summary}</p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
