---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { bioData } from '../../data/bio'
---
<BaseLayout title="Now | Iliass Tahiri" description="Current focus and priorities">
  <div class="container" style="padding-bottom: 80px;">
    <section class="page-hero">
      <span class="kicker">Now</span>
      <h1 class="section-title">What I am focused on right now.</h1>
      <p class="lead">A living snapshot of priorities, projects, and skills.</p>
    </section>

    <p class="mono-link" style="margin-bottom: 32px;">Last updated: March 24, 2026</p>

    <section class="section split">
      <div class="section-band stack">
        <h2 style="margin-bottom: 12px;">Current Focus</h2>
        <p>
          Reservoir geomechanics for depletion and CO2 injection, with an emphasis on wellbore
          stability, compaction-driven subsidence, and stress-path sensitivity.
        </p>
        <span class="pill">Last updated: March 21, 2026</span>
      </div>
      <div class="stack">
        <div class="note-card">
          <span class="pill">Skills in Motion</span>
          <p>Stress path interpretation, poromechanics calibration, and uncertainty framing.</p>
        </div>
        <div class="note-card">
          <span class="pill">Collaborations</span>
          <p>Working closely with reservoir engineers, drilling teams, and data science partners.</p>
        </div>
      </div>
    </section>

    <section class="section" style="max-width: 960px; margin: 0 auto;">
      <h2 class="section-title" style="font-size: 1.8rem;">Active Projects</h2>
      <div class="post-grid" style="margin-top: 24px;">
        <article class="post-card">
          <h3>CO2 Injection Geomechanics Playbook</h3>
          <p>Standardizing workflows to evaluate stress reversals, fault reactivation, and caprock integrity.</p>
        </article>
        <article class="post-card">
          <h3>Wellbore Stability Modeling</h3>
          <p>Integrating log-derived stresses with calibrated plasticity models in MFront.</p>
        </article>
        <article class="post-card">
          <h3>Subsidence Forecasting</h3>
          <p>Coupling field monitoring with GEOSX runs to improve compaction predictions.</p>
        </article>
      </div>
    </section>

    <section class="section" style="max-width: 960px; margin: 0 auto;">
      <h2 class="section-title" style="font-size: 1.8rem;">Learning & Reading</h2>
      <div class="card-grid" style="margin-top: 24px;">
        <div class="interest-card">
          <h3>Geomechanics Literature</h3>
          <p>Deep-diving on compaction banding, poroplasticity, and caprock integrity studies.</p>
        </div>
        <div class="interest-card">
          <h3>Tooling</h3>
          <p>Refining GEOSX workflows and improving MFront constitutive libraries.</p>
        </div>
        <div class="interest-card">
          <h3>Communication</h3>
          <p>Building clear narratives around uncertainty, risk, and model limitations.</p>
        </div>
      </div>
    </section>

    {bioData.bookshelf && (
      <section class="section" style="max-width: 960px; margin: 0 auto;">
        <h2 class="section-title">Bookshelf</h2>
        {bioData.bookshelf.current?.length > 0 && (
          <>
            <h3>Currently reading</h3>
            <ul>
              {bioData.bookshelf.current.map((book) => (
                <li><strong>{book.title}</strong>{book.author ? ` — ${book.author}` : ''}</li>
              ))}
            </ul>
          </>
        )}
        {bioData.bookshelf.recent?.length > 0 && (
          <>
            <h3>Recently finished</h3>
            <ul>
              {bioData.bookshelf.recent.map((book) => (
                <li><strong>{book.title}</strong>{book.author ? ` — ${book.author}` : ''}</li>
              ))}
            </ul>
          </>
        )}
      </section>
    )}
  </div>
</BaseLayout>
