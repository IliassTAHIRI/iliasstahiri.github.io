---
import Navbar from '../components/Navbar.jsx'
import Footer from '../components/Footer.jsx'
import '../styles/global.css'

const {
  title = 'Iliass Tahiri | Geomechanics',
  description = 'Iliass Tahiri - Senior Geomechanics Engineer',
  ogType = 'website',
  ogImage = '/assets/img/Ductal.jpeg',
  canonical,
  structuredData = null
} = Astro.props

const site = Astro.site?.href || 'https://iliasstahiri.github.io'
const canonicalUrl = canonical || new URL(Astro.url.pathname, site).href
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, site).href

const defaultStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Iliass Tahiri',
    url: site,
    jobTitle: 'Senior Geomechanics Engineer',
    knowsAbout: [
      'Reservoir geomechanics',
      'CO2 injection',
      'Wellbore stability',
      'Compaction and subsidence',
      'Poromechanics',
      'Plasticity modeling'
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Iliass Tahiri',
    url: site
  }
]

const jsonLd = structuredData ? structuredData : defaultStructuredData
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="370Vj1tXf1-IjakzUG7VfZu2cJaDnjjq-FtoSiK4lGg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Iliass Tahiri" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  </head>
  <body>
    <div class="app-container">
      <Navbar />
      <main id="content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
